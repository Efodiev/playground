generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Playground {
  id          String   @id @default(cuid())
  name        String
  description String?
  address     String
  city        String
  lat         Float
  lng         Float
  type        String   @default("kids") // kids | sports | both
  condition   String   @default("good") // excellent | good | needs_repair | dangerous
  rating      Int      @default(0) // 0-100 auto-calculated score
  status      String   @default("pending") // pending | approved | rejected
  photos      String   @default("[]") // JSON array of base64 data URLs
  equipment   String   @default("[]") // JSON array of equipment names
  submitterName  String?
  submitterEmail String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
